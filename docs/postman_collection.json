{
  "info": {
    "name": "POS Distributor Material - API",
    "description": "Collection untuk testing seluruh endpoint backend Sistem POS Distributor Material.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "PASTE_TOKEN_DISINI" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sync Profile",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/sync"
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        },
        {
          "name": "Get Category By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories/:id"
          }
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/categories",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Palu\",\n  \"description\": \"Kategori alat pukul\"\n}"
            }
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/categories/:id",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Palu Updated\",\n  \"description\": \"Deskripsi baru\"\n}"
            }
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/categories/:id"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "categoryId", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Product By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/:id"
          }
        },
        {
          "name": "Get Product By Barcode",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/barcode/8991234567890"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/products",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Palu Kambing 0.5kg\",\n  \"sku\": \"PLU-001\",\n  \"barcode\": \"8991234567890\",\n  \"unit\": \"pcs\",\n  \"price\": 35000,\n  \"cost_price\": 25000,\n  \"stock_quantity\": 50,\n  \"min_stock_threshold\": 10\n}"
            }
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/products/:id",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 40000,\n  \"stock_quantity\": 100\n}"
            }
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/products/:id"
          }
        }
      ]
    },
    {
      "name": "Inventory",
      "item": [
        {
          "name": "Get Inventory Logs",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/inventory/logs"
          }
        },
        {
          "name": "Get Low Stock Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/inventory/low-stock"
          }
        },
        {
          "name": "Adjust Stock",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/inventory/adjust",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"GANTI-DENGAN-UUID-PRODUK\",\n  \"quantityChange\": 20,\n  \"type\": \"in\",\n  \"note\": \"Barang masuk dari supplier\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Stores",
      "item": [
        {
          "name": "Get All Stores",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/stores"
          }
        },
        {
          "name": "Get Store By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/stores/:id"
          }
        },
        {
          "name": "Create Store",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/stores",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Toko Bangunan Jaya\",\n  \"owner_name\": \"Bapak Slamet\",\n  \"phone\": \"081234567890\",\n  \"address\": \"Jl. Raya No. 10, Bandung\"\n}"
            }
          }
        },
        {
          "name": "Update Store",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/stores/:id",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"089876543210\"\n}"
            }
          }
        },
        {
          "name": "Delete Store",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/stores/:id"
          }
        }
      ]
    },
    {
      "name": "Payment Schedules",
      "item": [
        {
          "name": "Get Calendar View",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/schedules/calendar?month=7&year=2026",
              "query": [
                { "key": "month", "value": "7" },
                { "key": "year", "value": "2026" }
              ]
            }
          }
        },
        {
          "name": "Get All Schedules",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/schedules"
          }
        },
        {
          "name": "Create Schedule",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/schedules",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"store_id\": \"GANTI-DENGAN-UUID-TOKO\",\n  \"amount\": 1500000,\n  \"due_date\": \"2026-07-31\",\n  \"notes\": \"Pembayaran termin 1\"\n}"
            }
          }
        },
        {
          "name": "Mark As Paid",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/schedules/:id/mark-paid"
          }
        },
        {
          "name": "Delete Schedule",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/schedules/:id"
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/transactions/checkout",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"storeId\": null,\n  \"paymentMethod\": \"cash\",\n  \"paymentStatus\": \"paid\",\n  \"notes\": \"Transaksi test\",\n  \"items\": [\n    {\n      \"productId\": \"GANTI-DENGAN-UUID-PRODUK\",\n      \"quantity\": 2\n    }\n  ]\n}"
            }
          }
        },
        {
          "name": "Get All Transactions",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions"
          }
        },
        {
          "name": "Get Transaction By ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions/:id"
          }
        },
        {
          "name": "Get Receipt",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/transactions/:id/receipt"
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Weekly Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports?period=weekly",
              "query": [{ "key": "period", "value": "weekly" }]
            }
          }
        },
        {
          "name": "Monthly Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/reports?period=monthly",
              "query": [{ "key": "period", "value": "monthly" }]
            }
          }
        }
      ]
    }
  ]
}